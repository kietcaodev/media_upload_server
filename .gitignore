node_modules/
uploads/
logs/

# ── Môi trường (chứa token, password – KHÔNG commit) ──
.env
.env.local
.env.*.local
*.env
# .env.example được phép commit (không có giá trị thực)

# ── Log files ──
*.log
*.log.*
npm-debug.log*

# ── OS ──
.DS_Store
Thumbs.db

# ── Editor ──
*.swp
*.swo
.vscode/settings.json

# ── .NET build output ──
backend/**/bin/
backend/**/obj/

# ── .NET user-specific ──
*.user
*.suo
.vs/

# ── EF migrations snapshot (optional – thường commit migrations) ──
# backend/**/Migrations/  ← giữ lại để deploy auto-migrate

# ── Frontend build output ──
frontend/**/dist/
frontend/**/.cache/

# ── Frontend env (riêng trong subfolder) ──
frontend/**/.env
frontend/**/.env.local
frontend/**/.env.*.local

# ── npm / package manager ──
# LƯU Ý: package-lock.json PHẢI được commit – deploy.sh dùng "npm ci" (yêu
# cầu bắt buộc có lockfile) để cài đặt reproducible trên VPS.

# ── Node (root level – từ project Node.js cũ) ──
node_modules/

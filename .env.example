# ============================================================
# .env.example – Template cấu hình
# Copy file này thành .env rồi điền giá trị thực
#   cp .env.example .env
#
# ⚠️  File .env đã được git-ignore, KHÔNG commit .env lên git
# ============================================================

# ==================== SERVER ====================
PORT=8000
NODE_ENV=development
# production | development

# ==================== TIMEZONE ====================
# IANA timezone ID – dùng cho log và hiển thị
TIMEZONE=Asia/Ho_Chi_Minh

# ==================== CORS ====================
# Danh sách origin được phép, phân cách bằng dấu phẩy
# Dùng * để cho phép tất cả (chỉ dùng khi dev)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== UPLOAD ====================
# Dung lượng tối đa mỗi file (bytes). 1500MB = 1572864000
MAX_FILE_SIZE=1572864000

# Số file tối đa trong 1 request
MAX_FILES_PER_REQUEST=5

# Dung lượng NAS tối thiểu trước khi từ chối upload (bytes). 1GB = 1073741824
MIN_DISK_SPACE=1073741824

# ==================== ĐƯỜNG DẪN ====================
UPLOAD_DIR=/mnt/nas/uploads
LOGS_DIR=/mnt/nas/logs
METADATA_FILE=/mnt/nas/metadata.json

# ==================== RATE LIMITING ====================
# Cửa sổ tính rate limit (milliseconds). 15 phút = 900000
RATE_LIMIT_WINDOW_MS=900000

# Số request tối đa trong 1 cửa sổ
RATE_LIMIT_MAX_REQUESTS=20

# ==================== LOGGING ====================
# Mức log: error | warn | info | debug
LOG_LEVEL=info

# ================================================================
# 🔐 PHẦN NHẠY CẢM – CHỈ ĐIỀN TRONG .env, KHÔNG COMMIT LÊN GIT
# ================================================================

# API Token dùng để xác thực request upload (Bearer token)
# Tạo ngẫu nhiên: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
API_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN

# ---------- DND ERP ----------
ERP_DND_URL=https://locnuoc365.xyz/api/order/upload-videos
ERP_DND_TOKEN=REPLACE_WITH_DND_JWT_TOKEN

# ---------- Zomzem ERP ----------
ERP_ZOMZEM_URL=https://zomzem.xyz/api/order/upload-videos
ERP_ZOMZEM_TOKEN=REPLACE_WITH_ZOMZEM_JWT_TOKEN

# ---------- Zozin ERP ----------
ERP_ZOZIN_URL=https://erp.zozin.vn/api/order/upload-videos
ERP_ZOZIN_TOKEN=REPLACE_WITH_ZOZIN_JWT_TOKEN
